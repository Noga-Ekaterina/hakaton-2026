{
  "name": "hakaton-2026",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "preview": "npm run preview --prefix apps/web",
    "dev:all": "turbo run dev --parallel",
    "build:all": "turbo run build",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:server": "npm run dev --prefix apps/server",
    "db:push": "npm run db:push --prefix apps/server",
    "db:seed": "npm run db:seed --prefix apps/server"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
