generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  AWAITING_INSPECTION
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskEventType {
  TASK_CREATED
  TASK_UPDATED
  STATUS_UPDATED
  STORY_POINTS_UPDATED
  TAGS_UPDATED
}

model Project {
  id        Int       @id @default(autoincrement())
  name      String
  users     User[]
  tasks     Task[]
  tags      TaskTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id                    Int                        @id @default(autoincrement())
  name                  String
  email                 String                     @unique
  password              String
  role                  UserRole                   @default(USER)
  projects              Project[]
  refreshSessions       RefreshSession[]
  authoredTasks         Task[]                     @relation("TaskAuthor")
  assignedTasks         Task[]                     @relation("TaskAssignee")
  taskComments          TaskComment[]              @relation("TaskCommentAuthor")
  taskEvents            TaskEvent[]                @relation("TaskEventActor")
  notificationsAssignee TaskNotificationAssignee[] @relation("TaskNotificationAssignee")
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
}

model RefreshSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Task {
  id               Int                       @id @default(autoincrement())
  title            String
  description      String                    @db.Text
  status           TaskStatus                @default(NEW)
  priority         TaskPriority              @default(MEDIUM)
  storyPoints      Int?
  authorId         Int
  assigneeId       Int
  projectId        Int
  tags             TaskTag[]
  author           User                      @relation("TaskAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  assignee         User                      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  project          Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  images           TaskImage[]
  comments         TaskComment[]
  events           TaskEvent[]
  notification     TaskNotificationAssignee?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([authorId])
  @@index([assigneeId])
  @@index([projectId])
}

model TaskImage {
  id        Int      @id @default(autoincrement())
  taskId    Int
  name      String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  taskId    Int
  authorId  Int
  body      String    @db.Text
  isDeleted Boolean   @default(false)
  editedAt  DateTime?
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User      @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([taskId, createdAt])
  @@index([authorId])
}

model TaskEvent {
  id        Int           @id @default(autoincrement())
  taskId    Int
  actorId   Int?
  type      TaskEventType
  changes   Json?
  metadata  Json?
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User?         @relation("TaskEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([taskId, createdAt])
  @@index([actorId])
}

model TaskTag {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#64748b")
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model TaskNotificationAssignee {
  id         Int      @id @default(autoincrement())
  assigneeId Int
  taskId     Int      @unique
  assignee   User     @relation("TaskNotificationAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([assigneeId, createdAt])
  @@index([taskId, createdAt])
}
